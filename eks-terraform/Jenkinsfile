pipeline {
  agent any

  parameters {
    booleanParam(
      name: 'DESTROY_INFRA',
      defaultValue: false,
      description: '⚠️ Destroy ALL Terraform-managed infrastructure (EKS, VPC, etc.)'
    )
  }

  options {
    timestamps()
    disableConcurrentBuilds()               // prevents two builds from fighting Terraform state
    durabilityHint('MAX_SURVIVABILITY')     //  pipeline survives Jenkins hiccups/restarts better
  }

  environment {
    AWS_REGION = 'us-east-1'
    DOCKERHUB_USERNAME = 'veecode34'
    FRONTEND_IMAGE = 'smartloss-frontend'
    BACKEND_IMAGE  = 'smartloss-backend'
    EKS_CLUSTER_NAME = 'my-cluster'
    K8S_NAMESPACE = 'smartloss'
    TF_VAR_admin_principal_arn = 'arn:aws:iam::980805786514:user/EseVic'
  }

  stages {
    stage('Checkout Code') {
      steps { checkout scm }
    }

    stage('Compute Tag') {
      when { expression { params.DESTROY_INFRA == false } }
      steps {
        script {
          def sha = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
          env.TAG = "${sha}-${env.BUILD_NUMBER}"
        }
      }
    }

    stage('Terraform Init & Apply (EKS)') {
      when { expression { params.DESTROY_INFRA == false } }
      steps {
        withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'AWS_CREEDS']]) {
          dir('eks-terraform') {
            sh '''
              set -euo pipefail
              terraform init -reconfigure   # CHANGED: forces correct backend/state (S3). Prevents destroy using "wrong" state.
              terraform fmt -check || true
              terraform validate
              terraform apply -auto-approve -no-color | tee tf-apply.log   # CHANGED: stable logging
            '''
          }
        }
      }
    }

    stage('Configure AWS & EKS') {
      when { expression { params.DESTROY_INFRA == false } }
      steps {
        withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'AWS_CREEDS']]) {
          sh '''
            set -euo pipefail
            aws eks update-kubeconfig --region "$AWS_REGION" --name "$EKS_CLUSTER_NAME"
            kubectl get nodes
          '''
        }
      }
    }

    stage('Docker Login') {
      when { expression { params.DESTROY_INFRA == false } }
      steps {
        withCredentials([
          usernamePassword(
            credentialsId: 'docker_creds',
            usernameVariable: 'DOCKER_USER',
            passwordVariable: 'DOCKER_PASS'
          )
        ]) {
          sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin'
        }
      }
    }

    stage('Build Docker Images') {
      when { expression { params.DESTROY_INFRA == false } }
      steps {
        dir('backend')  { sh "docker build -t $DOCKERHUB_USERNAME/$BACKEND_IMAGE:$TAG ." }
        dir('frontend') { sh "docker build -t $DOCKERHUB_USERNAME/$FRONTEND_IMAGE:$TAG ." }
      }
    }

    stage('Push Docker Images') {
      when { expression { params.DESTROY_INFRA == false } }
      steps {
        sh """
          docker push $DOCKERHUB_USERNAME/$BACKEND_IMAGE:$TAG
          docker push $DOCKERHUB_USERNAME/$FRONTEND_IMAGE:$TAG
        """
      }
    }

    stage('Deploy to EKS') {
      when { expression { params.DESTROY_INFRA == false } }
      steps {
        withCredentials([
          [$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'AWS_CREEDS'],
          string(credentialsId: 'render-postgres-uri', variable: 'RENDER_POSTGRES_URI')
        ]) {
          dir('kubernetes-files') {
            sh """
              set -euo pipefail
              aws eks update-kubeconfig --region "$AWS_REGION" --name "$EKS_CLUSTER_NAME"

              # Update image tags
              sed -i 's|image: .*smartloss-backend.*|image: $DOCKERHUB_USERNAME/$BACKEND_IMAGE:$TAG|g' backend-deploy.yaml
              sed -i 's|image: .*smartloss-frontend.*|image: $DOCKERHUB_USERNAME/$FRONTEND_IMAGE:$TAG|g' frontend-deploy.yaml

              kubectl apply -f namespace.yaml
              kubectl apply -f configmap.yaml

              # DB Secret injected securely
              cat <<EOF | kubectl apply -f -
apiVersion: v1
kind: Secret
metadata:
  name: smartloss-db-secret
  namespace: $K8S_NAMESPACE
type: Opaque
stringData:
  POSTGRES_URI: "$RENDER_POSTGRES_URI"
EOF

              kubectl apply -f backend-deploy.yaml
              kubectl apply -f frontend-deploy.yaml

              kubectl rollout status deployment/smartloss-backend -n $K8S_NAMESPACE --timeout=600s   # CHANGED: longer timeout (EKS pulls can be slow)
              kubectl rollout status deployment/smartloss-frontend -n $K8S_NAMESPACE --timeout=600s  # CHANGED: longer timeout

              kubectl get svc -n $K8S_NAMESPACE
            """
          }
        }
      }
    }

    // ======================
    // DESTROY PATH (CLEAN)
    // ======================

    stage('Pre-Destroy: Delete Kubernetes Workloads (remove LBs/ENIs)') {
      when { expression { params.DESTROY_INFRA == true } }
      steps {
        withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'AWS_CREEDS']]) {
          sh '''
            set +e

            # CHANGED: delete k8s stuff FIRST so AWS LoadBalancers/ENIs created by Services are removed.
            # Those often block subnet/IGW/VPC deletion (the "some resources could not be deleted" error).
            aws eks update-kubeconfig --region "$AWS_REGION" --name "$EKS_CLUSTER_NAME" 2>/dev/null

            kubectl delete namespace "$K8S_NAMESPACE" --ignore-not-found=true
            kubectl wait --for=delete ns/"$K8S_NAMESPACE" --timeout=900s || true
          '''
        }
      }
    }

    stage('Terraform Destroy (EKS & Infra)') {
      when { expression { params.DESTROY_INFRA == true } }
      steps {
        timeout(time: 60, unit: 'MINUTES') { // CHANGED: destroy can take a long time (EKS + VPC)
          withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'AWS_CREEDS']]) {
            dir('eks-terraform') {
              sh '''
                set -euo pipefail
                terraform init -reconfigure   # CHANGED: ensures destroy uses S3 state (same resources created)

                # CHANGED: retry because AWS deletions are sometimes eventual-consistency flaky
                for i in 1 2 3; do
                  echo "===== terraform destroy attempt $i/3 ====="
                  terraform destroy -auto-approve -no-color 2>&1 | tee tf-destroy.log && exit 0
                  echo "Destroy attempt $i failed. Sleeping 60s then retry..."
                  sleep 60
                done

                echo "Terraform destroy failed after 3 attempts."
                exit 1
              '''
            }
          }
        }
      }
    }
  }

  post {
    always { sh 'docker logout || true' }
    failure { echo '❌ Pipeline failed!' }
    success { echo '✅ Pipeline completed successfully!' }
  }
}